{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "src/index.ts",
    "src/core/**/*",
    "src/adapters/**/*",
    "src/lib/**/*",
    "src/types/**/*"
  ],
  "exclude": ["src/**/*.test.ts", "tests", "dist", "node_modules"]
}
